# .env -- copy this file's contents into a real .env in your project root.
# NEVER commit the real .env to git -- make sure .gitignore includes ".env"

# OpenRouter API key (https://openrouter.ai/keys)
# Used by core/category_engine.py for AI-fallback categorization.
OPENROUTER_API_KEY=paste_your_openrouter_key_here

# Optional: used in OpenRouter request headers for attribution.
OR_SITE_URL=https://varcrm.vercel.app
OR_APP_NAME=Vardhman BAS Workflow

# Existing project secrets (Supabase, etc.) should also live here if not
# already in a .env -- add them alongside the above, do not create a
# second env file.
